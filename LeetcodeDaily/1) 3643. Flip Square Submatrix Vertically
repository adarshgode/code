class Solution {
    public int[][] reverseSubmatrix(int[][] grid, int x, int y, int k) {
        int endRow = x + k -1;
        int endCol = y + k - 1;

        for(int i=x;i<endRow;i++){
            for(int j=y;j<=endCol;j++){
                grid[i][j] += grid[endRow][j];
                grid[endRow][j] = grid[i][j] - grid[endRow][j];
                grid[i][j] -= grid[endRow][j];
            }
            endRow--;
        }
        return grid;
    }
}
